<!DOCTYPE html>
<html lang="ja" x-data="app()" :data-theme="theme">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>F1 News</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
  <style>
    /* ── Tokens ─────────────────────────────────────────────── */
    :root {
      --red:       #E10600;
      --bg:        #0a0a0a;
      --surface:   #111111;
      --line:      #1f1f1f;
      --text:      #e8e8e8;
      --muted:     #555;
      --label:     #888;
      --chip-bg:   #1c1c1c;
      --chip-on:   #E10600;
      --chip-txt:  #e8e8e8;
      --chip-on-txt: #fff;
      --mono: "SF Mono", "Fira Code", "Cascadia Code", "Consolas", monospace;
      --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }
    :root[data-theme="light"],
    :root:not([data-theme="dark"]):has(+ * + * + *) {
      --bg:        #f4f4f2;
      --surface:   #ffffff;
      --line:      #e2e2e2;
      --text:      #111111;
      --muted:     #aaa;
      --label:     #666;
      --chip-bg:   #e8e8e8;
      --chip-txt:  #111;
    }
    @media (prefers-color-scheme: light) {
      :root:not([data-theme="dark"]) {
        --bg:        #f4f4f2;
        --surface:   #ffffff;
        --line:      #e2e2e2;
        --text:      #111111;
        --muted:     #aaa;
        --label:     #666;
        --chip-bg:   #e8e8e8;
        --chip-txt:  #111;
      }
    }

    /* ── Reset ──────────────────────────────────────────────── */
    [x-cloak] { display: none !important; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ── Header ─────────────────────────────────────────────── */
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid var(--line);
    }
    .header-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 24px 10px;
      gap: 16px;
    }
    .wordmark {
      display: flex;
      align-items: baseline;
      gap: 10px;
    }
    .wordmark-flag {
      background: var(--red);
      color: #fff;
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      padding: 2px 7px;
      border-radius: 2px;
    }
    .wordmark-title {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: -0.2px;
    }
    .header-meta {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .updated {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      white-space: nowrap;
    }
    .theme-btn {
      background: none;
      border: 1px solid var(--line);
      border-radius: 4px;
      color: var(--label);
      cursor: pointer;
      font-size: 14px;
      line-height: 1;
      padding: 5px 8px;
      transition: border-color 0.15s, color 0.15s;
    }
    .theme-btn:hover { border-color: var(--muted); color: var(--text); }

    /* ── Tab bar ─────────────────────────────────────────────── */
    .tab-bar {
      display: flex;
      padding: 0 24px;
      gap: 0;
    }
    .tab-btn {
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      color: var(--muted);
      cursor: pointer;
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 6px 14px 5px;
      margin-bottom: -1px;
      transition: color 0.12s, border-color 0.12s;
    }
    .tab-btn:hover { color: var(--text); }
    .tab-btn.tab-active { color: var(--text); border-bottom-color: var(--red); }

    /* ── Filter bar ──────────────────────────────────────────── */
    .filter-bar {
      padding: 10px 24px 12px;
      display: flex;
      align-items: center;
      gap: 10px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .filter-bar::-webkit-scrollbar { display: none; }
    .filter-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      flex-shrink: 0;
    }
    .chips { display: flex; gap: 6px; flex-wrap: nowrap; }
    .chip {
      background: var(--chip-bg);
      color: var(--chip-txt);
      border: none;
      border-radius: 3px;
      cursor: pointer;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 4px 10px;
      white-space: nowrap;
      transition: background 0.12s, color 0.12s, opacity 0.12s;
    }
    .chip[aria-pressed="true"]  { background: var(--chip-on); color: var(--chip-on-txt); opacity: 1; }
    .chip[aria-pressed="false"] { opacity: 0.45; }
    .chip:hover { opacity: 1 !important; }

    /* ── Main grid ───────────────────────────────────────────── */
    main {
      max-width: 1280px;
      margin: 0 auto;
      padding: 24px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1px;
      background: var(--line);
    }

    /* ── Source block ────────────────────────────────────────── */
    .source-block {
      background: var(--surface);
      padding: 20px 22px 18px;
      transition: opacity 0.18s;
    }
    .source-block.muted { opacity: 0.18; pointer-events: none; }

    .source-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--red);
    }
    .source-name {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text);
      text-decoration: none;
    }
    .source-name:hover { color: var(--red); }
    .source-count {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
    }

    /* ── Article list ────────────────────────────────────────── */
    .article-list {
      list-style: none;
      counter-reset: art;
    }
    .article-item {
      counter-increment: art;
      display: grid;
      grid-template-columns: 20px 1fr;
      gap: 0 8px;
      padding: 6px 0;
      border-bottom: 1px solid var(--line);
    }
    .article-item:last-child { border-bottom: none; }
    .article-num {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      padding-top: 2px;
      text-align: right;
      user-select: none;
    }
    .article-num::before { content: counter(art, decimal-leading-zero); }
    .article-link {
      color: var(--text);
      text-decoration: none;
      font-size: 13px;
      line-height: 1.45;
    }
    .article-link:hover { color: var(--red); }

    /* ── Trends section ─────────────────────────────────────── */
    .trends-wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding: 24px;
    }
    .trends-intro {
      font-size: 12px;
      color: var(--label);
      line-height: 1.6;
      margin-bottom: 22px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--line);
    }
    .trends-intro b { color: var(--text); font-weight: 700; }
    .trends-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1px;
      background: var(--line);
    }
    .trend-card {
      background: var(--surface);
      padding: 20px 22px 18px;
    }
    .trend-card-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--red);
    }
    .trend-card-title {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text);
    }
    .trend-card-sub {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
    }
    .bar-item { border-bottom: 1px solid var(--line); }
    .bar-item:last-child { border-bottom: none; }
    .bar-row {
      display: grid;
      grid-template-columns: 16px 100px 1fr 24px 12px;
      align-items: center;
      gap: 10px;
      padding: 7px 0;
      cursor: pointer;
    }
    .bar-rank {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      text-align: right;
    }
    .bar-name {
      font-size: 11px;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: color 0.12s;
    }
    .bar-row:hover .bar-name { color: var(--red); }
    .bar-track {
      position: relative;
      background: var(--chip-bg);
      border-radius: 3px;
      height: 8px;
      overflow: hidden;
    }
    .bar-fill {
      position: absolute;
      inset: 0 auto 0 0;
      height: 100%;
      background: linear-gradient(90deg, var(--red), #ff4d47);
      border-radius: 3px;
      min-width: 3px;
      transition: width 0.3s;
    }
    .bar-count {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--label);
      text-align: right;
    }
    .bar-caret {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--muted);
      text-align: center;
      line-height: 1;
      transition: transform 0.15s, color 0.15s;
    }
    .bar-caret.caret-open { transform: rotate(90deg); color: var(--red); }

    /* ── Article drill-down list (shared by bars & keywords) ─── */
    .bar-articles {
      list-style: none;
      margin: 0 0 8px;
      padding: 4px 0 6px 26px;
      border-left: 2px solid var(--red);
      margin-left: 6px;
    }
    .kw-articles { margin-top: 10px; }
    .bar-art {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 10px;
      padding: 5px 0;
    }
    .bar-art-link {
      color: var(--label);
      text-decoration: none;
      font-size: 12px;
      line-height: 1.45;
    }
    .bar-art-link:hover { color: var(--red); }
    .bar-art-src {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted);
      white-space: nowrap;
      flex-shrink: 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .keyword-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .keyword-tag {
      display: inline-flex;
      align-items: baseline;
      gap: 5px;
      background: var(--chip-bg);
      border: none;
      border-radius: 3px;
      padding: 5px 10px;
      color: var(--chip-txt);
      cursor: pointer;
      font-size: 11px;
      font-weight: 600;
      transition: background 0.12s, color 0.12s;
    }
    .keyword-tag:hover { color: var(--red); }
    .keyword-tag.kw-active { background: var(--chip-on); color: var(--chip-on-txt); }
    .keyword-tag .kw-count {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--red);
      font-weight: 700;
    }
    .keyword-tag.kw-active:hover { color: var(--chip-on-txt); }
    .keyword-tag.kw-active .kw-count { color: #fff; }
    .trends-empty {
      color: var(--muted);
      font-size: 13px;
      padding: 48px 0;
      text-align: center;
    }

    /* ── Schedule section ───────────────────────────────────── */
    .sched-wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding: 24px;
    }
    .sched-section-label {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .round-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1px;
      background: var(--line);
      margin-bottom: 28px;
    }
    .round-card {
      background: var(--surface);
      padding: 18px 20px 14px;
      border-left: 3px solid transparent;
    }
    .round-next { border-left-color: var(--red); }
    .next-badge {
      display: inline-block;
      background: var(--red);
      color: #fff;
      font-family: var(--mono);
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 1px 6px;
      border-radius: 2px;
      margin-bottom: 6px;
    }
    .round-num {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.08em;
    }
    .round-name {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
      margin: 3px 0 2px;
    }
    .round-loc {
      font-size: 11px;
      color: var(--label);
      margin-bottom: 12px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--line);
    }
    .session-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 4px 0;
      border-bottom: 1px solid var(--line);
      gap: 8px;
      transition: opacity 0.12s;
    }
    .session-row:last-child { border-bottom: none; }
    .session-row.session-past { opacity: 0.4; }
    .session-label {
      font-size: 11px;
      color: var(--label);
      flex-shrink: 0;
    }
    .session-time {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text);
      white-space: nowrap;
    }
    .sched-divider {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--muted);
      text-transform: uppercase;
      text-align: center;
      padding: 10px 0;
      margin-bottom: 20px;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .round-grid-past { opacity: 0.38; }
    .sched-empty {
      color: var(--muted);
      font-size: 13px;
      padding: 48px 0;
      text-align: center;
    }

    /* ── Footer ──────────────────────────────────────────────── */
    footer {
      text-align: center;
      padding: 20px;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.06em;
      color: var(--muted);
      border-top: 1px solid var(--line);
      margin-top: 1px;
    }

    /* ── Responsive ──────────────────────────────────────────── */
    @media (max-width: 640px) {
      .header-top { padding: 12px 16px 8px; }
      .tab-bar { padding: 0 16px; }
      .filter-bar  { padding: 8px 16px 10px; }
      main { padding: 0; grid-template-columns: 1fr; }
      .source-block { padding: 16px; }
      .sched-wrap { padding: 16px; }
      .round-grid { grid-template-columns: 1fr; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { transition: none !important; animation: none !important; }
    }
  </style>
</head>
<body>

<header>
  <div class="header-top">
    <div class="wordmark">
      <span class="wordmark-flag">F1</span>
      <span class="wordmark-title">News</span>
    </div>
    <div class="header-meta">
      <span class="updated">{{ updated_at }}</span>
      <button class="theme-btn" @click="toggleTheme()" :aria-label="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'">
        <span x-text="theme === 'dark' ? '☀' : '☾'"></span>
      </button>
    </div>
  </div>
  <div class="tab-bar">
    <button class="tab-btn" :class="{ 'tab-active': tab === 'news' }" @click="tab = 'news'">NEWS</button>
    <button class="tab-btn" :class="{ 'tab-active': tab === 'trends' }" @click="tab = 'trends'">TRENDS</button>
    <button class="tab-btn" :class="{ 'tab-active': tab === 'schedule' }" @click="tab = 'schedule'">SCHEDULE</button>
  </div>
  <div class="filter-bar" x-show="tab === 'news'">
    <span class="filter-label">Source</span>
    <div class="chips">
      <button
        class="chip"
        :aria-pressed="String(allActive)"
        @click="toggleAll()"
      >ALL</button>
      {% for source in sources %}
      <button
        class="chip"
        :aria-pressed="String(active.has('{{ source.key }}'))"
        @click="toggle('{{ source.key }}')"
      >{{ source.name }}</button>
      {% endfor %}
    </div>
  </div>
</header>

<main x-show="tab === 'news'">
  {% for source in sources %}
  <div
    class="source-block"
    :class="{ muted: !active.has('{{ source.key }}') }"
  >
    <div class="source-head">
      <a class="source-name" href="{{ source.url }}" target="_blank" rel="noopener noreferrer">{{ source.name }}</a>
      <span class="source-count">{{ source.articles | length }}</span>
    </div>
    <ol class="article-list">
      {% for article in source.articles %}
      <li class="article-item">
        <span class="article-num"></span>
        <a class="article-link" href="{{ article.link }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
      </li>
      {% endfor %}
    </ol>
  </div>
  {% endfor %}
</main>

{% macro bar_list(items, name_key) -%}
  {% for it in items %}
  <div class="bar-item" x-data="{ open: false }">
    <div
      class="bar-row"
      @click="open = !open"
      role="button"
      tabindex="0"
      @keydown.enter="open = !open"
      @keydown.space.prevent="open = !open"
      :aria-expanded="String(open)"
    >
      <span class="bar-rank">{{ "%02d" | format(loop.index) }}</span>
      <span class="bar-name" title="{{ it[name_key] }}">{{ it[name_key] }}</span>
      <div class="bar-track">
        <div class="bar-fill" style="width: {{ [it.pct, 6] | max }}%"></div>
      </div>
      <span class="bar-count">{{ it.count }}</span>
      <span class="bar-caret" :class="{ 'caret-open': open }">&rsaquo;</span>
    </div>
    <ul class="bar-articles" x-show="open" x-transition.opacity x-cloak>
      {% for a in (it.articles or []) %}
      <li class="bar-art">
        <a class="bar-art-link" href="{{ a.link }}" target="_blank" rel="noopener noreferrer">{{ a.title }}</a>
        {% if a.source %}<span class="bar-art-src">{{ a.source }}</span>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
{%- endmacro %}

<section class="trends-wrap" x-show="tab === 'trends'">
  {% if trends and trends.total_articles and (trends.drivers or trends.teams or trends.topics) %}
  <div class="trends-intro">
    直近 <b>{{ trends.total_articles }}</b> 本の記事タイトルを解析し、言及の多いキーワードを集計しています。
    数字は「言及した記事数」です。<b>LLM不使用・辞書ベースの簡易解析</b>のため、目安としてご覧ください。
  </div>
  <div class="trends-grid">
    {% if trends.drivers %}
    <div class="trend-card">
      <div class="trend-card-head">
        <span class="trend-card-title">Hot Drivers</span>
        <span class="trend-card-sub">記事数</span>
      </div>
      {{ bar_list(trends.drivers, "name") }}
    </div>
    {% endif %}

    {% if trends.teams %}
    <div class="trend-card">
      <div class="trend-card-head">
        <span class="trend-card-title">Hot Teams</span>
        <span class="trend-card-sub">記事数</span>
      </div>
      {{ bar_list(trends.teams, "name") }}
    </div>
    {% endif %}

    {% if trends.topics %}
    <div class="trend-card">
      <div class="trend-card-head">
        <span class="trend-card-title">Topics</span>
        <span class="trend-card-sub">記事数</span>
      </div>
      {{ bar_list(trends.topics, "name") }}
    </div>
    {% endif %}

    {% if trends.keywords %}
    <div class="trend-card" x-data="{ sel: null }">
      <div class="trend-card-head">
        <span class="trend-card-title">Trending Keywords</span>
        <span class="trend-card-sub">辞書外の頻出語</span>
      </div>
      <div class="keyword-cloud">
        {% for kw in trends.keywords %}
        <button
          class="keyword-tag"
          :class="{ 'kw-active': sel === {{ loop.index }} }"
          @click="sel = (sel === {{ loop.index }} ? null : {{ loop.index }})"
        >{{ kw.term }}<span class="kw-count">{{ kw.count }}</span></button>
        {% endfor %}
      </div>
      {% for kw in trends.keywords %}
      <ul class="bar-articles kw-articles" x-show="sel === {{ loop.index }}" x-transition.opacity x-cloak>
        {% for a in (kw.articles or []) %}
        <li class="bar-art">
          <a class="bar-art-link" href="{{ a.link }}" target="_blank" rel="noopener noreferrer">{{ a.title }}</a>
          {% if a.source %}<span class="bar-art-src">{{ a.source }}</span>{% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% else %}
  <div class="trends-empty">トレンドデータを算出できませんでした。</div>
  {% endif %}
</section>

{% set upcoming = schedule | selectattr("is_past", "equalto", false) | list %}
{% set past = schedule | selectattr("is_past") | list %}

<section class="sched-wrap" x-show="tab === 'schedule'">
  {% if schedule %}
    {% if upcoming %}
    <div class="sched-section-label">UPCOMING &mdash; {{ current_year }}</div>
    <div class="round-grid">
      {% for r in upcoming %}
      <div class="round-card{% if r.is_next %} round-next{% endif %}">
        {% if r.is_next %}<div class="next-badge">NEXT</div>{% endif %}
        <div class="round-num">{{ "RD %02d" | format(r.round) }}</div>
        <div class="round-name">{{ r.name }}</div>
        <div class="round-loc">{{ r.circuit }}&nbsp;&middot;&nbsp;{{ r.country }}</div>
        {% for s in r.sessions %}
        <div class="session-row{% if s.is_past %} session-past{% endif %}">
          <span class="session-label">{{ s.label }}</span>
          <span class="session-time">{{ s.dt_jst }}&thinsp;JST</span>
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if past %}
    <div class="sched-divider">{{ past | length }} round{{ 's' if past | length != 1 else '' }} completed</div>
    <div class="round-grid round-grid-past">
      {% for r in past | reverse %}
      <div class="round-card">
        <div class="round-num">{{ "RD %02d" | format(r.round) }}</div>
        <div class="round-name">{{ r.name }}</div>
        <div class="round-loc">{{ r.circuit }}&nbsp;&middot;&nbsp;{{ r.country }}</div>
        {% for s in r.sessions %}
        <div class="session-row session-past">
          <span class="session-label">{{ s.label }}</span>
          <span class="session-time">{{ s.dt_jst }}&thinsp;JST</span>
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if not upcoming and not past %}
    <div class="sched-empty">No schedule data for {{ current_year }}.</div>
    {% endif %}
  {% else %}
  <div class="sched-empty">Schedule data unavailable.</div>
  {% endif %}
</section>

<footer>AUTO-UPDATED EVERY 30 MIN &nbsp;&middot;&nbsp; GITHUB ACTIONS + S3</footer>

<script>
  const SOURCE_KEYS = {{ source_keys_json }};

  function app() {
    const saved = localStorage.getItem('f1-theme');
    const osLight = window.matchMedia('(prefers-color-scheme: light)').matches;
    return {
      theme:  saved || (osLight ? 'light' : 'dark'),
      tab:    'news',
      active: new Set(SOURCE_KEYS),

      get allActive() { return this.active.size === SOURCE_KEYS.length; },

      toggle(key) {
        if (this.active.has(key)) {
          if (this.active.size > 1) { const s = new Set(this.active); s.delete(key); this.active = s; }
        } else {
          this.active = new Set([...this.active, key]);
        }
      },

      toggleAll() {
        this.active = this.allActive ? new Set([SOURCE_KEYS[0]]) : new Set(SOURCE_KEYS);
      },

      toggleTheme() {
        this.theme = this.theme === 'dark' ? 'light' : 'dark';
        localStorage.setItem('f1-theme', this.theme);
      },
    };
  }
</script>
<script src="https://unpkg.com/alpinejs@3.14.9/dist/cdn.min.js" defer></script>
</body>
</html>
